<Window x:Class="PlugINCivil3D.Presentation.Views.CulvertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Culvert Creator" Height="540" Width="480" WindowStartupLocation="CenterScreen">
    <ScrollViewer>
        <StackPanel Margin="12">
            <TextBlock Text="Culvert ID" FontWeight="Bold"/>
            <TextBlock Text="{Binding Model.Id}" Margin="0,0,0,8"/>
            <TextBlock Text="Station" FontWeight="Bold"/>
            <TextBlock Text="{Binding Model.Station}" Margin="0,0,0,8"/>
            <TextBlock Text="USIL" FontWeight="Bold"/>
            <TextBox Text="{Binding Model.Usil, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="DSIL" FontWeight="Bold"/>
            <TextBox Text="{Binding Model.Dsil, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="Slope" FontWeight="Bold"/>
            <TextBlock Text="{Binding Model.Slope}" Margin="0,0,0,8"/>
            <TextBlock Text="Skew" FontWeight="Bold"/>
            <TextBlock Text="{Binding Model.SkewAngle}" Margin="0,0,0,8"/>
            <TextBlock Text="Coverage warning active" Foreground="Red"/>
            <Button Content="Validate" Command="{Binding ValidateCommand}" Margin="0,8,0,4"/>
            <Button Content="Generate" Command="{Binding GenerateCommand}" Margin="0,0,0,4"/>
            <Button Content="Export Report" Command="{Binding ExportReportCommand}"/>
        </StackPanel>
    </ScrollViewer>
</Window>
